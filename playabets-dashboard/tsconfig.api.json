{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".vercel/output/functions",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["api/**/*"],
  "exclude": ["node_modules"]
}
